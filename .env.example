# Required: Meta API access token (System User or long-lived user token)
META_ACCESS_TOKEN=your_access_token_here

# Optional: Default ad account ID (saves passing it to every tool)
META_AD_ACCOUNT_ID=act_123456789

# Optional: API version override (default: v28.0)
META_API_VERSION=v28.0

# Optional: MCP server URL for .mcp.json (used by Claude Code)
META_MCP_URL=https://your-deployment-url.up.railway.app/mcp
