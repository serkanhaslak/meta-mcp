# Optional: Fallback Meta API access token (System User or long-lived user token)
# If not set, callers MUST provide their token via X-Meta-Token header on each session/request.
META_ACCESS_TOKEN=your_access_token_here

# Optional: Default ad account ID (saves passing it to every tool/request)
# Can also be overridden per session/request via X-Meta-Account-Id header.
META_AD_ACCOUNT_ID=act_123456789

# Optional: API version override (default: v28.0)
META_API_VERSION=v28.0

# Recommended: API key to protect the server (set on Railway + in .env locally)
# When set, all /mcp and /api/* requests require Authorization: Bearer <key>
MCP_API_KEY=your_api_key_here

# Optional: Server port (default: 3000)
# On Railway, set PORT=3000 to match the domain routing (EXPOSE 3000 in Dockerfile)
PORT=3000

# Optional: Server URL for .mcp.json env var interpolation (used by Claude Code)
META_MCP_URL=https://your-deployment-url.up.railway.app/mcp
